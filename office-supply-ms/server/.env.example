PORT=3001
MONGODB_URI=mongodb://localhost:27017/osms
CLIENT_ORIGIN=http://localhost:5173

JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
BCRYPT_ROUNDS=12
LOW_STOCK_THRESHOLD=5

# DIAL AI integration
DIAL_API_ENDPOINT=https://your-dial-endpoint
DIAL_API_KEY=replace-with-dial-api-key
DIAL_TIMEOUT_MS=20000

# SMTP mail integration
MAIL_ENABLED=false
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=mailer@example.com
MAIL_PASS=replace-with-mail-password
MAIL_FROM=OSMS Notifications <mailer@example.com>
