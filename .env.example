# MongoDB (include credentials when deployed via docker-compose)
MONGODB_URI=mongodb://mongo:27017/osms
MONGO_USERNAME=
MONGO_PASSWORD=

# JWT — generate strong secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Both MUST be at least 32 characters or the server will refuse to start.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Inventory
LOW_STOCK_THRESHOLD=5

# bcrypt
BCRYPT_ROUNDS=12

# Seed — required, no default
SEED_ADMIN_EMAIL=admin@company.com
SEED_ADMIN_PASSWORD=

# Optional: restrict self-registration to this email domain (e.g. company.com)
ALLOWED_EMAIL_DOMAIN=
